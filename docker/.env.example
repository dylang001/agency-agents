# ── Claude Code ──────────────────────────────────────────────
# Your Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# ── Workspace ─────────────────────────────────────────────────
# Absolute path to the local project directory mounted as /workspace.
# Defaults to the repo root if not set.
WORKSPACE_PATH=/path/to/your/project

# ── Airtable MCP ──────────────────────────────────────────────
# Personal access token from airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=pat...

# ── N8N MCP ───────────────────────────────────────────────────
# Port N8N is running on (default: 5678)
N8N_PORT=5678
# API token from N8N → Settings → API → Create API key
N8N_API_TOKEN=eyJ...
