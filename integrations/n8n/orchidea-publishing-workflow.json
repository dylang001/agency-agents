      "id": "twitter-type-check",
      "name": "Twitter — Is Thread?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [580, 340]
    },
    {
      "parameters": {
        "jsCode": "// Split thread body into individual tweets\n// Body format: \"1/ tweet text\\n2/ tweet text\\n...\"\nconst body = $input.first().json.Body;\nconst lines = body.split('\\n').filter(l => l.trim());\nconst tweets = lines\n  .filter(l => /^\\d+\\//.test(l.trim()))\n  .map(l => l.replace(/^\\d+\\/\\s*/, '').trim());\n\n// Return array of tweet objects for posting as reply chain\nreturn tweets.map((text, i) => ({\n  json: {\n    ...$input.first().json,\n    _tweetText: text,\n    _tweetIndex: i,\n    _totalTweets: tweets.length\n  }\n}));"
      },
      "id": "twitter-thread-splitter",
      "name": "Twitter — Split Thread",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 420]
    },
