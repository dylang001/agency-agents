    {
      "parameters": {
        "method": "POST",
        "url": "https://api.convertkit.com/v3/broadcasts",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"api_secret\": \"{{ $credentials.apiSecret }}\",\n  \"subject\": \"{{ $json.Body.match(/SUBJECT:\\s*([^\\n]+)/i)?.[1]?.trim() || $json.Headline }}\",\n  \"content\": \"{{ $json.Body.replace(/SUBJECT:[^\\n]+\\n?/i, '').replace(/PREVIEW TEXT:[^\\n]+\\n?/i, '').replace(/---\\n?/, '').trim() }}\",\n  \"description\": \"orchidea.digital weekly newsletter — content engine\",\n  \"public\": false,\n  \"published_at\": \"{{ $json['Scheduled Date'] }}T08:00:00-05:00\",\n  \"email_address\": {\n    \"from_name\": \"Dylan from orchidea.digital\",\n    \"reply_to\": \"dylan@orchidea.digital\"\n  }\n}",
        "options": {}
      },
      "id": "convertkit-broadcast",
      "name": "ConvertKit — Create Broadcast",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 780],
      "credentials": {
        "httpQueryAuth": {
          "id": "convertkit-credential-id",
          "name": "ConvertKit API — orchidea.digital"
        }
      },
      "notes": "Creates broadcast as draft (public: false) so you can preview before first automated send. Flip to public: true once confirmed formatting is correct."
    },

    {
      "parameters": {
        "jsCode": "// Normalize the published URL from each platform's API response\nconst item = $input.first().json;\nlet publishedUrl = item._publishedUrl || '';\n\nif (!publishedUrl) {\n  // LinkedIn ugcPost — returns id as urn:li:ugcPost:...\n  if (item.id && typeof item.id === 'string' && item.id.startsWith('urn:li:')) {\n    publishedUrl = `https://www.linkedin.com/feed/update/${item.id}`;\n  }\n  // Twitter — returns data.id\n  else if (item.data && item.data.id) {\n    publishedUrl = `https://twitter.com/orchideadigital/status/${item.data.id}`;\n  }\n  // Instagram media_publish — returns id (media ID, not permalink)\n  else if (item.id && typeof item.id === 'string' && !item.id.includes('_') && !item.id.startsWith('urn:')) {\n    publishedUrl = `https://www.instagram.com/p/${item.id}`;\n  }\n  // Facebook feed post — returns id as pageId_postId\n  else if (item.id && typeof item.id === 'string' && item.id.includes('_')) {\n    publishedUrl = `https://www.facebook.com/permalink.php?story_fbid=${item.id.split('_')[1]}&id=${item.id.split('_')[0]}`;\n  }\n  // ConvertKit — returns { broadcast: { id, ... } }\n  else if (item.broadcast && item.broadcast.id) {\n    publishedUrl = `https://app.convertkit.com/broadcasts/${item.broadcast.id}`;\n  }\n  // LinkedIn carousel upload — step 1 returns asset URN, not a live URL yet\n  else if (item.value && item.value.asset) {\n    publishedUrl = `linkedin-asset:${item.value.asset}`;\n  }\n}\n\nreturn [{ json: { ...item, _publishedUrl: publishedUrl } }];"
      },
      "id": "extract-url",
      "name": "Extract Published URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 480]
    },

