    {
      "parameters": {
        "jsCode": "// Blog posts are published by Framer's native Airtable sync — no API call needed.\n// This node just constructs the expected published URL from the Headline slug\n// so the writeback can record it. Framer syncs when Status = Approved.\nconst item = $input.first().json;\nconst slug = (item.Headline || '')\n  .toLowerCase()\n  .replace(/[^a-z0-9]+/g, '-')\n  .replace(/(^-|-$)/g, '');\nreturn [{\n  json: {\n    ...item,\n    _publishedUrl: `https://orchidea.digital/blog/${slug}`\n  }\n}];"
      },
      "id": "blog-framer-sync",
      "name": "Blog — Framer Syncs via Airtable",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 160],
      "notes": "No API call — Framer reads directly from this Airtable base via its native integration. This node only derives the published URL from the Headline so the writeback can record it. Ensure your Framer CMS collection is connected to the Content Queue table and set to sync when Status = Approved."
    },

