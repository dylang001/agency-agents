        "jsCode": "// Attach Airtable record ID to item so writeback node can find the record\n// Airtable trigger returns 'id' as the record ID\nconst item = $input.first().json;\nreturn [{\n  json: {\n    ...item,\n    _airtableRecordId: item.id || item._airtableRecordId\n  }\n}];"
      },
