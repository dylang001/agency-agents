      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 340],
      "credentials": {
        "oAuth2Api": {
          "id": "twitter-credential-id",
          "name": "Twitter OAuth2 — orchidea.digital"
        }
      },
      "notes": "For threads: the Body field contains numbered tweets (1/ ... 2/ ... 12/). The Code node before this splits them into individual tweets and posts as a reply chain. See the Twitter Thread Splitter node."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
