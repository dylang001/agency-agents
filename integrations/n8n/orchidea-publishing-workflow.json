    {
      "parameters": {
        "method": "POST",
        "url": "https://api.convertkit.com/v3/broadcasts",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"api_secret\": \"{{ $credentials.apiSecret }}\",\n  \"subject\": \"{{ $json.Body.match(/SUBJECT:\\s*([^\\n]+)/i)?.[1]?.trim() || $json.Headline }}\",\n  \"content\": \"{{ $json.Body.replace(/SUBJECT:[^\\n]+\\n?/i, '').replace(/PREVIEW TEXT:[^\\n]+\\n?/i, '').replace(/---\\n?/, '').trim() }}\",\n  \"description\": \"orchidea.digital weekly newsletter — Cycle automated by content engine\",\n  \"public\": false,\n  \"published_at\": \"{{ $json['Scheduled Date'] }}T08:00:00-05:00\",\n  \"email_address\": {\n    \"from_name\": \"Dylan from orchidea.digital\",\n    \"reply_to\": \"dylan@orchidea.digital\"\n  }\n}",
        "options": {}
      },
      "id": "convertkit-broadcast",
      "name": "ConvertKit — Create Broadcast",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 740],
      "credentials": {
        "httpQueryAuth": {
          "id": "convertkit-credential-id",
          "name": "ConvertKit API — orchidea.digital"
        }
      },
      "notes": "Creates the broadcast as a draft (public: false). To auto-send instead of draft, set published_at to now and public: true. ConvertKit API secret lives in your ConvertKit account settings."
    },
    {
      "parameters": {
        "jsCode": "// Merge all upstream branch results back into one stream\n// Each branch passes its result with a publishedUrl field\nconst item = $input.first().json;\nreturn [{ json: item }];"
      },
      "id": "merge-results",
      "name": "Merge Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 420]
    },
    {
      "parameters": {
        "jsCode": "// Extract published URL from upstream API response\n// Each platform returns differently — normalize here\nconst item = $input.first().json;\nlet publishedUrl = '';\n\n// Blog (Framer) — returns item with slug\nif (item._platform === 'Blog' || item.slug) {\n  publishedUrl = `https://orchidea.digital/blog/${item.slug || ''}`;\n}\n// LinkedIn — returns id as urn:li:share:...\nelse if (item.id && item.id.startsWith('urn:li:')) {\n  const postId = item.id.replace('urn:li:share:', '').replace('urn:li:ugcPost:', '');\n  publishedUrl = `https://www.linkedin.com/feed/update/${item.id}`;\n}\n// Twitter — returns data.id\nelse if (item.data && item.data.id) {\n  publishedUrl = `https://twitter.com/orchideadigital/status/${item.data.id}`;\n}\n// Instagram — returns id\nelse if (item.id && !item.id.startsWith('urn:')) {\n  publishedUrl = `https://www.instagram.com/p/${item.id}`;\n}\n// Facebook — returns id as pageId_postId\nelse if (item.id && item.id.includes('_')) {\n  publishedUrl = `https://www.facebook.com/${item.id}`;\n}\n// ConvertKit — returns broadcast with id\nelse if (item.broadcast && item.broadcast.id) {\n  publishedUrl = `https://app.convertkit.com/broadcasts/${item.broadcast.id}`;\n}\n\nreturn [{ json: { ...item, _publishedUrl: publishedUrl } }];"
      },
      "id": "extract-url",
      "name": "Extract Published URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 420]
    },
