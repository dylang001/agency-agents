        "authentication": "oAuth2",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"text\": \"{{ $json['Content Type'] === 'thread' ? $json.Body.split('\\n')[0].replace(/^1\\/\\s*/, '') : $json.Body }}\"\n}",
        "options": {}
